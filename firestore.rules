rules_version = '2';

// Multi-tenant model: every business record lives under shops/{shopId}/...
// so different owners' data is physically separated, not just filtered.
// users/{uid} stays top-level (queried before we know a shopId) and carries
// a shopId field marking which shop it belongs to.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasProfile() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Signed-in, has a profile, and that profile belongs to this shop.
    function inShop(shopId) {
      return hasProfile() && myProfile().shopId == shopId;
    }

    function isAdminOfShop(shopId) {
      return inShop(shopId) && myProfile().access == 'Admin';
    }

    function myRole(shopId) {
      return get(/databases/$(database)/documents/shops/$(shopId)/roles/$(myProfile().roleId)).data;
    }

    function hasPermission(shopId, key) {
      return isAdminOfShop(shopId)
        || (inShop(shopId)
            && myProfile().roleId != null
            && exists(/databases/$(database)/documents/shops/$(shopId)/roles/$(myProfile().roleId))
            && myRole(shopId).permissions[key] == true);
    }

    // users: self can read/create their own uid-keyed doc (bootstrap or
    // invite claim); Admins manage everyone within their own shop, including
    // email-keyed pending invites they created.
    match /users/{userId} {
      allow read: if isSignedIn()
        && (request.auth.uid == userId
            || userId == request.auth.token.email
            || (hasProfile() && myProfile().access == 'Admin' && resource.data.shopId == myProfile().shopId));
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId)
        || (hasProfile() && myProfile().access == 'Admin' && resource.data.shopId == myProfile().shopId);
      allow delete: if (hasProfile() && myProfile().access == 'Admin' && resource.data.shopId == myProfile().shopId)
        || (isSignedIn() && resource.data.email == request.auth.token.email);
    }

    // shops: created by whoever is about to own it (their profile doc
    // doesn't exist yet at that instant); read/updated only by members.
    match /shops/{shopId} {
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow read: if inShop(shopId);
      allow update: if isAdminOfShop(shopId);
      allow delete: if false;

      match /products/{id} {
        allow read: if inShop(shopId);
        allow write: if hasPermission(shopId, 'manageInventory');
      }

      match /purchases/{id} {
        allow read: if inShop(shopId);
        allow write: if hasPermission(shopId, 'recordPurchases');
      }

      match /sales/{id} {
        allow read: if inShop(shopId);
        allow create: if hasPermission(shopId, 'recordSales');
        allow update: if hasPermission(shopId, 'recordSales') || hasPermission(shopId, 'viewReports');
        allow delete: if isAdminOfShop(shopId);
      }

      match /expenses/{id} {
        allow read: if inShop(shopId);
        allow write: if hasPermission(shopId, 'addExpenses');
      }

      match /suppliers/{id} {
        allow read: if inShop(shopId);
        allow write: if isAdminOfShop(shopId);
      }

      match /roles/{id} {
        allow read: if inShop(shopId);
        allow write: if isAdminOfShop(shopId);
      }
    }
  }
}
